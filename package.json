{
  "name": "svelte-docinfo",
  "version": "0.5.3",
  "description": "static analysis for TypeScript and Svelte",
  "glyph": "📜",
  "logo": "logo.svg",
  "logo_alt": "a cyan scroll with curling ends",
  "license": "MIT",
  "homepage": "https://svelte-docinfo.fuz.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fuzdev/svelte-docinfo.git"
  },
  "keywords": [
    "svelte",
    "typescript",
    "documentation",
    "static-analysis",
    "api-docs",
    "component",
    "jsdoc",
    "tsdoc",
    "vite-plugin"
  ],
  "scripts": {
    "start": "gro dev",
    "dev": "gro dev",
    "build": "gro build",
    "check": "gro check",
    "test": "gro test",
    "setup-examples": "npm install --prefix examples/api && npm install --prefix examples/vite",
    "preview": "vite preview",
    "deploy": "gro deploy"
  },
  "type": "module",
  "bin": {
    "svelte-docinfo": "dist/main.js"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "commander": "^14.0.3",
    "es-module-lexer": "^2.0.0",
    "picomatch": "^4.0.4",
    "tinyglobby": "^0.2.15",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "svelte2tsx": "^0.7.30",
    "zod": "^4"
  },
  "devDependencies": {
    "@fuzdev/blake3_wasm": "^0.1.1",
    "@fuzdev/fuz_code": "^0.46.0",
    "@fuzdev/fuz_css": "^0.62.0",
    "@fuzdev/fuz_ui": "^0.203.1",
    "@fuzdev/fuz_util": "^0.65.1",
    "@fuzdev/gro": "^0.204.0",
    "@ryanatkn/eslint-config": "^0.12.1",
    "@sveltejs/acorn-typescript": "^1.0.9",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/estree": "^1.0.8",
    "@types/node": "^24.10.4",
    "@types/picomatch": "^4.0.2",
    "@webref/css": "^8.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.19.0",
    "esm-env": "^1.2.2",
    "magic-string": "^0.30.21",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte2tsx": "^0.7.55",
    "tslib": "^2.8.1",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.15",
    "zimmerframe": "^1.1.4",
    "zod": "^4.3.6"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-svelte"
    ],
    "useTabs": true,
    "printWidth": 100,
    "singleQuote": true,
    "bracketSpacing": false,
    "overrides": [
      {
        "files": "package.json",
        "options": {
          "useTabs": false
        }
      }
    ]
  },
  "sideEffects": [],
  "files": [
    "dist",
    "virtual-svelte-docinfo.d.ts"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./virtual-svelte-docinfo.js": {
      "types": "./virtual-svelte-docinfo.d.ts"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./*.ts": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  }
}
